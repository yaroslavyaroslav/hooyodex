<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.hooyodex.agent</string>
  <key>ProgramArguments</key>
  <array>
    <string>$HOME/path/to/hooyodex</string>
    <string>--config</string>
    <string>$HOME/Library/Application Support/hooyodex/config.toml</string>
    <string>run</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>LimitLoadToSessionType</key>
  <string>Aqua</string>
  <key>WorkingDirectory</key>
  <string>$HOME/Library/Application Support/hooyodex</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>HOOYODEX_CONFIG</key>
    <string>$HOME/Library/Application Support/hooyodex/config.toml</string>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$HOME/.local/bin</string>
    <key>RUST_LOG</key>
    <string>info</string>
  </dict>
  <key>StandardOutPath</key>
  <string>$HOME/Library/Logs/hooyodex.out.log</string>
  <key>StandardErrorPath</key>
  <string>$HOME/Library/Logs/hooyodex.err.log</string>
</dict>
</plist>
