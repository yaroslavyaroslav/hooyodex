[Unit]
Description=Hooyodex Telegram Orchestrator
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=__BIN__ --config %h/.config/hooyodex/config.toml run
WorkingDirectory=%h/.config/hooyodex
Environment=HOOYODEX_CONFIG=%h/.config/hooyodex/config.toml
Environment=RUST_LOG=info
Restart=on-failure
RestartSec=5
ExecReload=/bin/kill -HUP $MAINPID

[Install]
WantedBy=default.target
